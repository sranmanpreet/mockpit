# Copy to .env, fill in values, then `docker compose -f docker-compose.prod.yml up -d`.
# Do NOT commit the resulting .env to source control - it contains secrets.

POSTGRES_USER=mockpit
POSTGRES_PASSWORD=replace-me-with-something-strong

# Generate with: openssl rand -base64 48
MOCKPIT_JWT_SECRET=replace-with-base64-of-at-least-32-random-bytes

# Generate with: openssl rand 32 | base64
MOCKPIT_SECRET_CIPHER_KEY=replace-with-base64-of-exactly-32-random-bytes

# Comma-separated list. No wildcards in production.
MOCKPIT_ALLOWED_ORIGINS=https://mockpit.example.com

# What the SPA tells the browser is the API base URL (must be reachable from clients).
PUBLIC_BACKEND_URL=https://mockpit.example.com

# Bootstrap admin (only seeded on a fresh DB). Disable after first login.
MOCKPIT_BOOTSTRAP_ADMIN_ENABLED=true
MOCKPIT_BOOTSTRAP_ADMIN_EMAIL=admin@mockpit.example.com
MOCKPIT_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password
